@using System.Security.Claims
@{
    bool isAuth = User.Identity.IsAuthenticated;
    string userName = isAuth ? User.Identity.Name : "";
    int userIdRol = isAuth ? int.Parse(User.FindFirstValue("IdRol") ?? "0") : 0;
    string userImagen = isAuth ? User.FindFirstValue("Imagen") ?? "default.png" : "default.png";
    int userId = isAuth ? int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "0") : 0;
}
<!DOCTYPE html>
<html lang="es" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Soporte</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    
    <!-- Tailwind and Fonts -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0984E3",
                        "background-light": "#F5F6F7",
                        "accent-cyan": "#00CEC9",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "1rem",
                        "xl": "1.5rem",
                        "2xl": "2rem",
                    },
                },
            },
        }
    </script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #FFFFFF;
        }
        .bento-card {
            background-color: #ffffff;
            border: 1px solid rgba(0, 0, 0, 0.1); /* Borde negro fino y minimalista */
            box-shadow: none; /* Eliminamos sombras para un look purista */
            transition: all 0.38s cubic-bezier(0.4, 0, 0.2, 1);
        }
        /* Solo queremos el efecto lift en tarjetas marcadas explícitamente como interactivas */
        .bento-card-interactive:hover {
            border-color: rgba(0, 0, 0, 0.3);
            transform: translateY(-4px);
        }
        .glass-nav {
            backdrop-filter: blur(20px);
            background: rgba(255, 255, 255, 0.9);
            border-bottom: 2px solid #000000; /* Borde inferior negro minimalista */
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="text-slate-900 font-display min-h-screen flex flex-col">

    <!-- Top Navigation Bar -->
    <header class="sticky top-0 z-50 w-full border-b border-black/10 bg-white/95 backdrop-blur-md">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 relative">
            <div class="flex items-center gap-3 shrink-0">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-black/10 text-slate-900">
                    <span class="material-symbols-outlined">confirmation_number</span>
                </div>
                <div>
                    <h1 class="text-lg font-bold tracking-tight text-slate-900">Soporte</h1>
                </div>
            </div>

            @if (isAuth)
            {
                <nav class="absolute left-1/2 -translate-x-1/2 hidden md:flex items-center gap-8">
                    @if (userIdRol != 3) {
                        <a asp-controller="Home" asp-action="Index" class="text-sm font-semibold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-primary" : "text-slate-600 hover:text-primary transition-colors")">Dashboard</a>
                    }
                    <a asp-controller="Incidencias" asp-action="Index" class="text-sm font-semibold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Incidencias" ? "text-primary" : "text-slate-600 hover:text-primary transition-colors")">Tickets</a>
                    @if (userIdRol == 1)
                    {
                        <a asp-controller="Usuarios" asp-action="Index" class="text-sm font-semibold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "text-primary" : "text-slate-600 hover:text-primary transition-colors")">Usuarios</a>
                    }
                </nav>

                <div class="flex items-center ml-auto">
                    @await Component.InvokeAsync("Notificaciones")

                    <div class="group relative flex items-center gap-3 shrink-0 cursor-pointer p-1.5 md:px-4 rounded-2xl hover:bg-slate-50 transition-all border border-transparent hover:border-slate-100">
                        <div class="hidden sm:block text-right">
                        <p class="text-sm font-bold text-slate-700">@userName</p>
                        <p class="text-[10px] font-bold text-primary uppercase tracking-wider">@(userIdRol == 1 ? "Admin" : userIdRol == 2 ? "Tecnico" : "Usuario")</p>
                    </div>
                    <div class="h-10 w-10 overflow-hidden rounded-full border-2 border-slate-100">
                        <img alt="Perfil" class="h-full w-full object-cover" src="~/uploads/@userImagen" onerror="this.src='https://ui-avatars.com/api/?name=@userName&background=0984E3&color=fff'" />
                    </div>

                    <!-- Mega Dropdown -->
                    <div class="absolute right-0 top-full w-56 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50 pt-3">
                        <div class="bg-white rounded-[1.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.15)] border border-slate-100 py-3 flex flex-col items-stretch">
                            <div class="px-5 py-2 mb-2 border-b border-slate-50">
                                <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Cuenta</p>
                            </div>
                            <a asp-controller="Usuarios" asp-action="Details" asp-route-id="@userId" class="px-5 py-2 hover:bg-slate-50 flex items-center gap-3 text-sm font-bold text-slate-700 transition-colors">
                                <span class="material-symbols-outlined text-[20px] text-slate-400">person</span>
                                Mi Perfil
                            </a>
@*                             <a href="#" class="px-5 py-2 hover:bg-slate-50 flex items-center gap-3 text-sm font-bold text-slate-700 transition-colors">
                                <span class="material-symbols-outlined text-[20px] text-slate-400">settings</span>
                                Ajustes
                            </a> *@
                            <div class="h-px bg-slate-50 my-2 mx-5"></div>
                            <a asp-controller="Auth" asp-action="Logout" class="px-5 py-2 hover:bg-red-50 flex items-center gap-3 text-sm font-bold text-red-600 transition-colors">
                                <span class="material-symbols-outlined text-[20px]">logout</span>
                                Cerrar Sesión
                            </a>
                        </div>
                    </div>
                </div>
                </div>
            }
            else
            {
                <div class="ml-auto">
                    <a asp-controller="Auth" asp-action="Login" class="bg-primary text-white px-5 py-2 rounded-xl text-sm font-bold shadow-lg shadow-primary/20 hover:brightness-110 transition-all">Iniciar Sesión</a>
                </div>
            }
        </div>
    </header>

    <main class="w-full max-w-7xl mx-auto px-6 py-12 flex-1">
        @RenderBody()
    </main>

    <footer class="w-full border-t border-black/10 bg-white py-12 mt-auto">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
            <p class="text-[10px] font-black uppercase text-slate-400 tracking-[0.2em]">
                &copy; 2026 Sistema de Soporte
            </p>
            <a href="https://github.com/hctor12" target="_blank" class="group flex items-center gap-3 text-slate-400 hover:text-slate-900 transition-all duration-500">
                <span class="text-[9px] font-black uppercase tracking-widest opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500">hctor12</span>
                <svg class="w-6 h-6 fill-current transition-colors duration-500" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                </svg>
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        @if (isAuth)
        {
            <text>
            const presenceConnection = new signalR.HubConnectionBuilder()
                .withUrl("/presenceHub")
                .build();
            
            window.presenceConnection = presenceConnection;

            presenceConnection.on("ReceiveGlobalNotification", function (mensajeRaw, ticketId, ticketTitle, type) {
                // Los admins no reciben notificaciones de SignalR
                if (@userIdRol === 1) return;

                // Si estamos dentro del ticket correspondiente, ignoramos la alerta (ya lo estamos viendo)
                let pName = window.location.pathname.toLowerCase();
                let tId = ticketId || 0;
                if (tId && pName.includes('/incidencias/details/' + tId)) {
                    return;
                }

                let dropDownList = document.querySelector('.max-h-64.overflow-y-auto');
                let existingAnchor = null;
                if (dropDownList && tId !== 0 && type) {
                    existingAnchor = Array.from(dropDownList.querySelectorAll('a')).find(a => 
                        a.getAttribute('href').includes('/Incidencias/Details/' + tId) &&
                        a.getAttribute('data-type') === type
                    );
                }

                let mensaje = mensajeRaw;
                let count = 1;

                if (type === "comment") {
                    if (existingAnchor) {
                        count = parseInt(existingAnchor.getAttribute('data-count') || "1") + 1;
                        mensaje = `Tienes nuevos mensajes de ${mensajeRaw}`;
                    } else {
                        mensaje = `Tienes un nuevo mensaje de ${mensajeRaw}`;
                    }
                } else {
                    count = 0;
                }

                // Crear un toast elegante oscuro tipo Password Edit
                const toast = document.createElement("div");
                toast.className = "fixed bottom-10 right-10 bg-slate-900 border border-white/10 text-white px-6 py-4 rounded-[2rem] shadow-2xl z-[300] flex items-center gap-4 transform transition-all translate-x-full opacity-0";
                toast.innerHTML = `
                    <div class="bg-primary/20 p-2 rounded-full hidden sm:flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-primary text-[20px]">notifications_active</span>
                    </div>
                    <p class="text-sm font-bold text-white flex-1">${type === "comment" ? `Tienes un nuevo mensaje de ${mensajeRaw}` : mensajeRaw}</p>
                    <button onclick="this.parentElement.remove()" class="text-slate-400 hover:text-white transition-colors ml-2 flex items-center shrink-0">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </button>
                `;
                document.body.appendChild(toast);
                
                // Mostrar con animación
                setTimeout(() => {
                    toast.classList.remove("translate-x-full", "opacity-0");
                }, 100);

                // Ocultar y remover a los 5 segundos
                setTimeout(() => {
                    if (document.body.contains(toast)) {
                        toast.classList.add("translate-x-full", "opacity-0");
                        setTimeout(() => toast.remove(), 500);
                    }
                }, 5000);
                
                // --- Actualizar Burbuja roja ---
                let totalNuevas = 1;
                let bubble = document.querySelector('.bg-red-500.rounded-full span');
                if (bubble) {
                    totalNuevas = parseInt(bubble.innerText) + 1;
                    bubble.innerText = totalNuevas;
                } else {
                    let notifContainer = document.querySelector('.group.cursor-pointer.mr-6');
                    if(notifContainer) {
                        let b = document.createElement('div');
                        b.className = "absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 ring-2 ring-white";
                        b.innerHTML = '<span class="text-[10px] font-bold text-white">1</span>';
                        notifContainer.appendChild(b);
                    }
                }

                // --- Actualizar el contador del Dropdown ---
                let headerMenu = document.querySelector('.px-5.py-2.mb-2.border-b.flex.justify-between.items-center');
                if (headerMenu) {
                    let pill = headerMenu.querySelector('.bg-primary\\/10');
                    if (pill) {
                        pill.innerText = totalNuevas + " Nuevas";
                    } else {
                        headerMenu.insertAdjacentHTML('beforeend', `<span class="bg-primary/10 text-primary text-[10px] font-bold px-2 py-0.5 rounded-full">${totalNuevas} Nuevas</span>`);
                    }
                }

                // --- Actualizar el Mega Dropdown ---
                if (dropDownList) {
                    // Si estaba "Todo al dia", lo borramos
                    let emptyNotif = dropDownList.querySelector('.opacity-60');
                    if (emptyNotif) emptyNotif.remove();
                    
                    // Asegurarnos de usar variables seguras, si vienen nulas poner fallback
                    let tTitle = ticketTitle || 'Incidencia';

                    // Si ya existía este ticket del mismo TIPO, lo removemos para ponerlo al principio actualizado
                    if(existingAnchor) {
                        existingAnchor.remove();
                    }

                    // En el HTML a insertar: preparamos el badge de conteo
                    let counterHtml = '';
                    if (type === "comment" && count > 0) {
                        counterHtml = `<span class="text-[10px] font-bold text-slate-500 bg-slate-100 px-1.5 py-0.5 rounded-md">${count}</span>`;
                    }

                    // HTML del nuevo item (reutilizamos estilos del Default.cshtml actualizados)
                    const notifHtml = `
                    <a href="/Incidencias/Details/${tId}" data-type="${type}" data-count="${count}" class="px-5 py-3 hover:bg-slate-50 flex flex-col gap-1 transition-colors border-b border-slate-50 last:border-0 relative">
                        <div class="flex items-center justify-between">
                            <p class="text-[12px] font-bold text-slate-800 line-clamp-1">#${tId} - ${tTitle}</p>
                            <div class="flex items-center gap-2">
                                ${counterHtml}
                                <div class="h-2 w-2 rounded-full bg-red-500 shrink-0 shadow-sm"></div>
                            </div>
                        </div>
                        <p class="text-[11px] text-slate-500 font-medium">${mensaje}</p>
                    </a>`;
                    
                    // Insertar al inicio de la lista
                    dropDownList.insertAdjacentHTML('afterbegin', notifHtml);
                    
                    // Agregar el botón 'Limpiar Notificaciones' si no existe
                    let menuWrapper = dropDownList.parentElement;
                    let btnClear = menuWrapper.querySelector('button[onclick="limpiarNotificaciones()"]');
                    if (!btnClear) {
                        const btnHtml = `
                        <button onclick="limpiarNotificaciones()" class="group w-full px-5 py-3 mt-2 border-t border-slate-50 bg-slate-50/50 hover:bg-red-50 cursor-pointer transition-colors text-center rounded-b-[1.5rem] flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[14px] text-red-500">clear_all</span>
                            <p class="text-[11px] font-bold text-slate-600 transition-colors group-hover:text-red-600">Limpiar notificaciones</p>
                        </button>`;
                        menuWrapper.insertAdjacentHTML('beforeend', btnHtml);
                    }
                }
            });

            // Función para limpiar todas las notificaciones
            window.limpiarNotificaciones = function() {
                fetch('/Incidencias/LimpiarNotificaciones', { method: 'POST' })
                .then(res => {
                    if(res.ok) {
                        // Borramos los items visualmente y la burbuja
                        let dropDownList = document.querySelector('.max-h-64.overflow-y-auto');
                        if (dropDownList) {
                            dropDownList.innerHTML = `
                            <div class="px-5 py-8 flex flex-col items-center justify-center text-center opacity-60">
                                <span class="material-symbols-outlined text-[32px] text-slate-300 mb-2">done_all</span>
                                <p class="text-xs font-bold text-slate-500">Todo al dia</p>
                                <p class="text-[10px] text-slate-400">No tienes notificaciones pendientes.</p>
                            </div>
                            `;
                        }
                        
                        let bubble = document.querySelector('.bg-red-500.rounded-full');
                        if(bubble) bubble.remove();

                        let headerNotifCounter = document.querySelector('.bg-primary\\/10.text-primary.text-\\[10px\\]');
                        if(headerNotifCounter) headerNotifCounter.remove();

                        let buttonLimpiar = document.querySelector('button[onclick="limpiarNotificaciones()"]');
                        if(buttonLimpiar) buttonLimpiar.remove();
                    }
                });
            };

            // Start the connection unless logic in a child page handles it, 
            // but we start it here so all pages keep the user online.
            presenceConnection.start().catch(err => console.error(err));
            </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

