@model IEnumerable<Tuple<ProyectoMVCNetCore.Models.Incidencia, string, string, int>>

<div class="relative group cursor-pointer mr-6 flex items-center justify-center h-10 w-10 rounded-xl hover:bg-slate-50 transition-colors">
    <span class="material-symbols-outlined text-slate-600 transition-colors group-hover:text-primary">
        notifications
    </span>
    
    @if (Model != null && Model.Any())
    {
        <div class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 ring-2 ring-white">
            <span class="text-[10px] font-bold text-white">@Model.Count()</span>
        </div>
    }

    <!-- Dropdown de Notificaciones -->
    <div class="absolute right-[-10px] top-full w-80 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50 pt-3">
        <div class="bg-white rounded-[1.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.15)] border border-slate-100 py-3 flex flex-col items-stretch overflow-hidden">
            <div class="px-5 py-2 mb-2 border-b border-slate-50 flex justify-between items-center">
                <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Notificaciones</p>
                @if (Model != null && Model.Any())
                {
                    <span class="bg-primary/10 text-primary text-[10px] font-bold px-2 py-0.5 rounded-full">@Model.Count() Nuevas</span>
                }
            </div>
            
            <div class="max-h-64 overflow-y-auto">
                @if (Model != null && Model.Any())
                {
                    foreach (var tupla in Model.OrderByDescending(t => t.Item1.IdIncidencia))
                    {
                        var inc = tupla.Item1;
                        var msj = tupla.Item2;
                        var tipo = tupla.Item3;
                        var count = tupla.Item4;
                        <a asp-controller="Incidencias" asp-action="Details" asp-route-id="@inc.IdIncidencia" data-type="@tipo" data-count="@count" class="px-5 py-3 hover:bg-slate-50 flex flex-col gap-1 transition-colors border-b border-slate-50 last:border-0 relative">
                            <div class="flex items-center justify-between">
                                <p class="text-[12px] font-bold text-slate-800 line-clamp-1">#@inc.IdIncidencia - @inc.Titulo</p>
                                <div class="flex items-center gap-2">
                                    @if(tipo == "comment" && count > 0)
                                    {
                                        <span class="text-[10px] font-bold text-slate-500 bg-slate-100 px-1.5 py-0.5 rounded-md">@count</span>
                                    }
                                    <div class="h-2 w-2 rounded-full bg-red-500 shrink-0 shadow-sm"></div>
                                </div>
                            </div>
                            <p class="text-[11px] text-slate-500 font-medium">@msj</p>
                        </a>
                    }
                }
                else
                {
                    <div class="px-5 py-8 flex flex-col items-center justify-center text-center opacity-60">
                        <span class="material-symbols-outlined text-[32px] text-slate-300 mb-2">done_all</span>
                        <p class="text-xs font-bold text-slate-500">Todo al dia</p>
                        <p class="text-[10px] text-slate-400">No tienes notificaciones pendientes.</p>
                    </div>
                }
            </div>
            
            @if (Model != null && Model.Any())
            {
                <button onclick="limpiarNotificaciones()" class="group w-full px-5 py-3 mt-2 border-t border-slate-50 bg-slate-50/50 hover:bg-red-50 cursor-pointer transition-colors text-center rounded-b-[1.5rem] flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[14px] text-red-500">clear_all</span>
                    <p class="text-[11px] font-bold text-slate-600 transition-colors group-hover:text-red-600">Limpiar notificaciones</p>
                </button>
            }
        </div>
    </div>
</div>

