@model Usuario
@{
    ViewData["Title"] = "Editar Usuario";
    List<Rol> roles = ViewData["Roles"] as List<Rol> ?? new List<Rol>();
}

<div class="max-w-4xl mx-auto py-10">
    <div class="mb-8">
        <a asp-action="Index" class="text-slate-500 hover:text-slate-900 transition-colors flex items-center gap-2 text-sm font-bold mb-4">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Volver al listado
        </a>
        <h2 class="text-4xl font-black text-slate-900 tracking-tight">Editar Usuario</h2>
        <p class="text-slate-500 font-medium mt-1">Modifica los datos del usuario</p>
    </div>

    <div class="bento-card rounded-[2.5rem] overflow-hidden">
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="p-10">
            <input type="hidden" name="idUsuario" value="@Model.IdUsuario" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
                <div class="space-y-6">
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Nombre Completo</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">person</span>
                            <input name="nombre" type="text" value="@Model.Nombre" required 
                                   class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Correo Electrónico</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">mail</span>
                            <input name="email" type="email" value="@Model.Email" required 
                                   class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold" />
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Rol en el Sistema</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">badge</span>
                            <select name="idRol" required 
                                    class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold appearance-none">
                                @foreach (var rol in roles)
                                {
                                    <option value="@rol.IdRol" selected="@(rol.IdRol == Model.IdRol)">@rol.NombreRol</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Imagen de Perfil</label>
                        <div class="flex items-center gap-6 p-4 bg-slate-50 rounded-2xl border border-black/5">
                            <img id="preview-img" src="~/uploads/@Model.Imagen" class="w-16 h-16 rounded-xl object-cover border border-black/10 shadow-sm transition-all duration-500" onerror="this.src='https://ui-avatars.com/api/?name=@Model.Nombre&background=random'" />
                            <div class="flex-1">
                                <label for="file-upload" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-black/10 rounded-xl text-xs font-black text-slate-600 hover:bg-slate-100 cursor-pointer transition-all active:scale-95">
                                    <span class="material-symbols-outlined text-sm">image_search</span>
                                    Cambiar Imagen
                                </label>
                                <input id="file-upload" name="imagen" type="file" class="hidden" accept="image/*" onchange="updatePreview(this)" />
                                <p id="file-name" class="text-[10px] text-slate-400 font-medium mt-1 truncate max-w-[150px]">Fichero actual: @Model.Imagen</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-8 border-t border-black/5">
                <a asp-action="Index" class="px-8 py-4 rounded-2xl font-bold text-sm text-slate-500 hover:bg-slate-50 transition-all border border-transparent">
                    Cancelar
                </a>
                <button id="saveBtn" type="submit" disabled class="bg-slate-100 text-slate-400 px-10 py-4 rounded-2xl font-black text-sm transition-all flex items-center gap-3 cursor-not-allowed">
                    <span class="material-symbols-outlined text-lg">save</span>
                    Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const initialValues = {
            nombre: "@Model.Nombre",
            email: "@Model.Email",
            idRol: "@Model.IdRol"
        };
        let imageChanged = false;

        function checkChanges() {
            const currentNombre = document.getElementsByName('nombre')[0].value;
            const currentEmail = document.getElementsByName('email')[0].value;
            const currentRol = document.getElementsByName('idRol')[0].value;
            
            const hasChanged = currentNombre !== initialValues.nombre || 
                               currentEmail !== initialValues.email || 
                               currentRol !== initialValues.idRol || 
                               imageChanged;

            const btn = document.getElementById('saveBtn');
            if (hasChanged) {
                btn.disabled = false;
                btn.classList.remove('bg-slate-100', 'text-slate-400', 'cursor-not-allowed');
                btn.classList.add('bg-slate-900', 'hover:bg-black', 'text-white', 'shadow-xl', 'shadow-slate-200', 'active:scale-95');
            } else {
                btn.disabled = true;
                btn.classList.add('bg-slate-100', 'text-slate-400', 'cursor-not-allowed');
                btn.classList.remove('bg-slate-900', 'hover:bg-black', 'text-white', 'shadow-xl', 'shadow-slate-200', 'active:scale-95');
            }
        }

        // Monitor inputs
        document.getElementsByName('nombre')[0].addEventListener('input', checkChanges);
        document.getElementsByName('email')[0].addEventListener('input', checkChanges);
        document.getElementsByName('idRol')[0].addEventListener('change', checkChanges);

        function updatePreview(input) {
            const fileNameDisplay = document.getElementById('file-name');
            const previewImg = document.getElementById('preview-img');
            
            if (input.files && input.files.length > 0) {
                imageChanged = true;
                const file = input.files[0];
                fileNameDisplay.textContent = "Archivo seleccionado: " + file.name;
                fileNameDisplay.classList.add('text-primary', 'font-bold');

                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.style.opacity = '0';
                    setTimeout(() => {
                        previewImg.src = e.target.result;
                        previewImg.style.opacity = '1';
                    }, 200);
                }
                reader.readAsDataURL(file);
                checkChanges();
            }
        }
    </script>
}
