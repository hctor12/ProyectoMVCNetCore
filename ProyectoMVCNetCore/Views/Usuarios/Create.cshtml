@model ProyectoMVCNetCore.Models.Usuario

@{
    ViewData["Title"] = "Crear Nuevo Usuario";
    List<Rol> roles = ViewData["Roles"] as List<Rol>;
}

<div class="max-w-4xl mx-auto pb-10">
    <div class="mb-8">
        <a asp-action="Index" class="text-slate-500 hover:text-slate-900 transition-colors flex items-center gap-2 text-sm font-bold mb-4">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Volver al listado
        </a>
        <h2 class="text-4xl font-black text-slate-900 tracking-tight">Crear Nuevo Usuario</h2>
        <p class="text-slate-500 font-medium mt-1">Registra nuevos usuarios para el sistema</p>
    </div>

    <div class="bento-card rounded-[2.5rem] overflow-hidden">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
                <div class="space-y-6">
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Nombre Completo</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">person</span>
                            <input name="nombre" type="text" placeholder="Ej: Juan Pérez" required 
                                   class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Correo Electrónico</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">mail</span>
                            <input name="email" type="email" placeholder="email@empresa.com" required 
                                   class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold" />
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Contraseña Temporal</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">lock</span>
                            <input name="password" type="password" placeholder="Mínimo 6 caracteres" required 
                                   class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Rol en el Sistema</label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">badge</span>
                            <select name="idRol" required 
                                    class="w-full pl-12 pr-5 py-4 bg-slate-50 border border-black/5 rounded-2xl focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all outline-none text-slate-800 font-bold appearance-none">
                                <option value="">Seleccione un rol...</option>
                                @foreach (var rol in roles)
                                {
                                    <option value="@rol.IdRol">@rol.NombreRol</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-10">
                <label class="block text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3 px-1">Imagen de Perfil</label>
                <div class="flex items-center justify-center w-full">
                    <label for="dropzone-file" class="flex flex-col items-center justify-center w-full h-32 border-2 border-black/10 border-dashed rounded-[1.5rem] cursor-pointer bg-slate-50 hover:bg-white hover:border-primary/50 transition-all duration-300">
                        <div class="flex flex-col items-center justify-center pt-5 pb-6">
                            <span class="material-symbols-outlined text-slate-400 text-3xl mb-2">cloud_upload</span>
                            <p class="text-xs text-slate-500"><span class="font-black">Haz clic para subir</span> o arrastra y suelta</p>
                            <p id="file-name-display" class="text-[10px] text-primary font-bold mt-1 italic hidden"></p>
                        </div>
                        <input id="dropzone-file" name="imagen" type="file" class="hidden" onchange="updateFileName(this)" />
                    </label>
                </div>
            </div>

            <div class="flex items-center justify-end pt-8 border-t border-black/5">
                <button type="submit" class="bg-slate-900 hover:bg-black text-white px-10 py-4 rounded-2xl font-black text-sm shadow-xl shadow-slate-200 transition-all flex items-center gap-3 active:scale-95">
                    <span class="material-symbols-outlined text-lg">person_add</span>
                    Registrar Usuario
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function updateFileName(input) {
            const fileNameDisplay = document.getElementById('file-name-display');
            if (input.files && input.files.length > 0) {
                fileNameDisplay.textContent = "Archivo seleccionado: " + input.files[0].name;
                fileNameDisplay.classList.remove('hidden');
            }
        }
    </script>
}
